project:
  type: book
  output-dir: docs

book:
  title: "Statistical analysis with Python"

  author-meta: "Moinul Islam"
  date-meta: today
  description-meta: |
    This book will teach you how to do statistical analysis with Python. Gaphics, literate
    programming to save time and make your work reproducible. Along the way,
    you'll also learn how to manage cognitive resources to facilitate
    discoveries when wrangling, visualising, and exploring data.

  reader-mode: true

  page-footer:
    left: |
      Statistical analysis with Python is written by Moinul Islam.
    right: |
      This book was built with <a href="https://quarto.org/">Quarto</a>.
  cover-image: cover.png

  chapters:
    - index.qmd
    - intro.qmd

    - part: section_1.qmd
      chapters:
        - chapter_1_1.qmd

    - part: section_2.qmd
      chapters:
        - chapter_2_1.qmd

    - part: section_3.qmd
      chapters:
        - chapter_3_1.qmd

    - part: section_4.qmd
      chapters:
        - chapter_4_1.qmd

    - part: section_5.qmd
      chapters:
        - chapter_5_1.qmd

format:
  html:
    theme:
      - cosmo
      - r4ds.scss
    cover-image: cover.png
    code-link: true
    include-in-header: "plausible.html"
    callout-appearance: simple

editor: visual
